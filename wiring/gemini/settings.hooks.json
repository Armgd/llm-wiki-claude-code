{
  "hooks": {
    "PostToolUse": [
      { "matcher": "Write|Edit",
        "hooks": [{ "type": "command", "command": "bash /ABS/PATH/TO/llm-wiki/hooks/scripts/wiki-notify.sh" }] },
      { "matcher": "",
        "hooks": [{ "type": "command", "command": "bash /ABS/PATH/TO/llm-wiki/hooks/scripts/wiki-inbox-nudge.sh" }] }
    ],
    "Stop": [
      { "hooks": [{ "type": "command", "command": "bash /ABS/PATH/TO/llm-wiki/hooks/scripts/wiki-stop.sh" }] }
    ]
  }
}
